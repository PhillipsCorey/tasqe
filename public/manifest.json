{
  "manifest_version": 3,
  "name": "tasqe",
  "version": "0.7.0",
  "description": "An extension to aid students in managing big tasks and their week as a whole.",
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
